# Called every frame. 'delta' is the elapsed time since the previous frame.
func _physics_process(delta: float) -> void:
	if player.health == 0:
		get_tree().change_scene_to_file("res://scenes/badend2.tscn")

	if isattacking == 0:
		if attacktim == 0:
			if attack == 0:
				add_child(tracker1)
				add_child(tracker2)
				add_child(tracker3)
				add_child(tracker4)
				add_child(tracker5)
				add_child(tracker6)
				add_child(tracker7)
				add_child(tracker8)
				add_child(tracker9)
				add_child(tracker10)
				isattacking = 1
				trackertim.start()
			elif attack == 1:
				add_child(spear1)
				isattacking = 1
				speartim.start()
			elif attack == 2:
				add_child(bones1)
				add_child(bones2)
				add_child(bones3)
				add_child(bones4)
				add_child(bones5)
				add_child(bones6)
				add_child(bones7)
				add_child(bones8)
				add_child(bones9)
				add_child(bones10)
				add_child(bones11)
				add_child(bones12)
				isattacking = 1
				skeletonstim.start()
			elif attack == 3:
				add_child(charger1)
				add_child(charger2)
				add_child(charger3)
				add_child(charger4)
				add_child(charger5)
				add_child(charger6)
				add_child(charger7)
				add_child(charger8)
				isattacking = 1
				chargetim.start()
		if attacktim == 1:
			if attack == 0:
				add_child(tracker1)
				add_child(tracker2)
				add_child(tracker3)
				add_child(tracker4)
				add_child(tracker5)
				add_child(tracker6)
				add_child(tracker7)
				add_child(tracker8)
				add_child(tracker9)
				add_child(tracker10)
				isattacking = 1
				trackertim.start()
			elif attack == 1:
				add_child(spear2)
				add_child(spear1)
				isattacking = 1
				speartim.start()
			elif attack == 2:
				attack = randi_range(0,3)
			elif attack == 3:
				add_child(charger1)
				add_child(charger2)
				add_child(charger3)
				add_child(charger4)
				add_child(charger5)
				add_child(charger6)
				add_child(charger7)
				add_child(charger8)
				add_child(bones1)
				add_child(bones2)
				add_child(bones3)
				add_child(bones4)
				add_child(bones5)
				add_child(bones6)
				add_child(bones7)
				add_child(bones8)
				add_child(bones9)
				add_child(bones10)
				add_child(bones11)
				add_child(bones12)
				isattacking = 1
				chargetim.start()



